#!/usr/bin/env python3

import socket
import json
import sys
import os


def notify(path):
    host = os.environ.get("ARANDU_HOST", "host.docker.internal")
    port = int(os.environ.get("ARANDU_PORT", "7474"))

    # Verificação rápida de disponibilidade via ping antes de enviar o open
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(2)
        s.connect((host, port))
        s.sendall(json.dumps({"command": "ping"}).encode() + b"\n")
        resp = s.recv(4096)
        s.close()
        result = json.loads(resp.decode().strip())
        if not result.get("success"):
            return  # arandu não respondeu ok
    except Exception:
        return  # arandu não está rodando

    # Envia o comando open
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(2)
        s.connect((host, port))
        s.sendall(json.dumps({"command": "open", "path": os.path.abspath(path)}).encode() + b"\n")
        resp = s.recv(4096)
        s.close()
        result = json.loads(resp.decode().strip())
        if not result.get("success"):
            print(f"[arandu] erro: {result.get('error', 'desconhecido')}", file=sys.stderr)
    except Exception as e:
        print(f"[arandu] falha ao enviar: {e}", file=sys.stderr)


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: arandu <path>", file=sys.stderr)
        sys.exit(1)
    notify(sys.argv[1])
